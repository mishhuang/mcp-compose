{
  "name": "mcp-compose",
  "version": "1.0.0",
  "description": "A TypeScript SDK for composing and routing across multiple MCP servers with typed tools, middleware, and Zod validation",
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mishhuang/mcp-compose.git"
  },
  "keywords": ["mcp", "model-context-protocol", "typescript", "sdk"],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mishhuang/mcp-compose/issues"
  },
  "homepage": "https://github.com/mishhuang/mcp-compose#readme",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
}
